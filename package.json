{
  "name": "prompt-atelier",
  "version": "1.1.0",
  "description": "Novel AI prompt and metadata desktop atelier.",
  "author": "Prompt Atelier",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "studio.promptatelier.app",
    "productName": "Prompt Atelier",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "gallery-fixes.js",
      "build/icon.png",
      "build/icon.ico",
      "electron/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "forceCodeSigning": false,
      "target": [
        "nsis"
      ],
      "artifactName": "Prompt Atelier Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Prompt Atelier",
      "uninstallDisplayName": "Prompt Atelier"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
